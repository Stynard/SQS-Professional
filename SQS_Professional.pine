//@version=6
//====================================================
// SQS Professional
// Version : 1.0.1 Beta
// Module  : Trend Engine
//====================================================


indicator("SQS Professional v1.0.1 Beta", overlay=true)

//====================================================
// INPUTS
//====================================================

emaLength    = input.int(20, "EMA Length")
sma50Length  = input.int(50, "50 SMA Length")
sma200Length = input.int(200, "200 SMA Length")

showEMA20  = input.bool(true, "Show 20 EMA")
showSMA50  = input.bool(true, "Show 50 SMA")
showSMA200 = input.bool(true, "Show 200 SMA")

//====================================================
// MOVING AVERAGES
//====================================================

ema20  = ta.ema(close, emaLength)
sma50  = ta.sma(close, sma50Length)
sma200 = ta.sma(close, sma200Length)

plot(showEMA20 ? ema20 : na, "20 EMA", color=color.green, linewidth=2)
plot(showSMA50 ? sma50 : na, "50 SMA", color=color.blue, linewidth=2)
plot(showSMA200 ? sma200 : na, "200 SMA", color=color.red, linewidth=3)

//====================================================
// HELPER FUNCTIONS
//====================================================

isAbove200() =>
    close > sma200

isBullAlignment() =>
    sma50 > sma200

is200Rising() =>
    sma200 > sma200[20]

is50Rising() =>
    sma50 > sma50[10]

isAbove50() =>
    close > sma50

isAbove20() =>
    close > ema20

is20Rising() =>
    ema20 > ema20[5]

//====================================================
// STRUCTURE SCORE
//====================================================

calcStructureScore() =>
    int score = 0

    if isAbove200()
        score += 20

    if isBullAlignment()
        score += 20

    if is200Rising()
        score += 15

    if is50Rising()
        score += 15

    score

//====================================================
// HEALTH SCORE
//====================================================

calcHealthScore() =>
    int score = 0

    if isAbove50()
        score += 10

    if isAbove20()
        score += 10

    if is20Rising()
        score += 10

    score

//====================================================
// SCORES
//====================================================

structureScore = calcStructureScore()
healthScore = calcHealthScore()
trendScore = structureScore + healthScore

//====================================================
// LETTER GRADE
//====================================================

grade = trendScore >= 95 ? "A+" : trendScore >= 90 ? "A"  : trendScore >= 85 ? "A-" : trendScore >= 80 ? "B+" : trendScore >= 75 ? "B"  : trendScore >= 70 ? "B-" : trendScore >= 60 ? "C"  : trendScore >= 40 ? "D"  : "F"

//====================================================
// RATING
//====================================================

rating =
     trendScore >= 90 ? "Leading Trend" :
     trendScore >= 80 ? "Strong Trend" :
     trendScore >= 70 ? "Healthy Trend" :
     trendScore >= 60 ? "Pullback" :
     trendScore >= 40 ? "Under Pressure" :
     "Downtrend"

//====================================================
// DASHBOARD COLORS
//====================================================

headerColor =
     trendScore >= 80 ? color.green :
     trendScore >= 60 ? color.orange :
     color.red

//====================================================
// DASHBOARD
//====================================================

var table dash = table.new(position.top_right, 2, 10, frame_width=1)

if barstate.islast

    table.cell(dash, 0, 0, "SQS Professional", bgcolor=headerColor, text_color=color.white)
    table.cell(dash, 1, 0, "v1.0.1 Beta", bgcolor=headerColor, text_color=color.white)

    table.cell(dash, 0, 1, "Grade")
    table.cell(dash, 1, 1, grade)

    table.cell(dash, 0, 2, "Trend Score")
    table.cell(dash, 1, 2, str.tostring(trendScore) + "/100")

    table.cell(dash, 0, 3, "Rating")
    table.cell(dash, 1, 3, rating)

    table.cell(dash, 0, 4, "Structure")
    table.cell(dash, 1, 4, str.tostring(structureScore) + "/70")

    table.cell(dash, 0, 5, "Health")
    table.cell(dash, 1, 5, str.tostring(healthScore) + "/30")

    table.cell(dash, 0, 6, "Relative Strength")
    table.cell(dash, 1, 6, "--")

    table.cell(dash, 0, 7, "Momentum")
    table.cell(dash, 1, 7, "--")

    table.cell(dash, 0, 8, "Institutional")
    table.cell(dash, 1, 8, "--")

    table.cell(dash, 0, 9, "Version")
    table.cell(dash, 1, 9, "1.0.1 Beta")

    table.cell(dash, 0, 10, "Status")
    table.cell(dash, 1, 10, rating)